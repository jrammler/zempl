const std = @import("std");

zempl Heading(title: []const u8) {
    <h1 class="heading">{title}</h1>
}

zempl Button(text: []const u8, disabled: bool) {
    <button 
        class="btn"
        disabled=disabled
        type="button"
    >
        {text}
    </button>
}

zempl Card(title: []const u8, showHeader: bool) {
    <div class="card">
        @if (showHeader) {
            <div class="card-header">
                @Heading(title)
            </div>
        } @else {
            <div class="card-header">
                <p>No header</p>
            </div>
        }
        <div class="card-body">
            <p>Welcome!</p>
        </div>
    </div>
}

zempl List(items: []const []const u8) {
    <ul>
        @for (items) |item| {
            <li>{item}</li>
        }
    </ul>
}

zempl Countdown(n: u32) {
    <div class="countdown">
        @while (n > 0) {
            <span>{n}</span>
            @{ n -= 1; }
        }
        <span>Done!</span>
    </div>
}

zempl Link(href: []const u8, userId: u32) {
    @{
        var buf: [100]u8 = undefined;
        const url = try std.fmt.bufPrint(&buf, "/{s}/{d}", .{ href, userId });
    }
    <a href=url>Click here</a>
}

zempl Page(name: []const u8) {
    <html>
        <head>
            <title>{name}</title>
        </head>
        <body>
            @Card("Welcome", true)
            @List(&.{ "apple", "banana", "cherry" })
            @Countdown(3)
            @Link("profile", 42)
        </body>
    </html>
}
