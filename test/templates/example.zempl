const std = @import("std");

const Card = zimport("components/card.zempl").Card;
const list = zimport("components/list.zempl");

zempl Countdown(count: u32) {
    <div class="countdown">
        @{ var n = count; }
        @while (n > 0) {
            <span>{n}</span>
            @{ n -= 1; }
        }
        <span>Done!</span>
    </div>
}

zempl Link(href: []const u8, userId: u32) {
    @{
        var buf: [100]u8 = undefined;
        const url = try std.fmt.bufPrint(&buf, "/{s}/{d}", .{ href, userId });
    }
    <a href="{url}">Click here</a>
    <a href="/{href}/{userId}">Or here</a>
}

pub zempl Page(name: []const u8, showDisabled: bool) {
    <!DOCTYPE html>
    <html>
        <head>
            <title>{name}</title>
        </head>
        <body>
            @Card("Welcome", true)
            @list.List(&.{ "apple", "banana", "cherry" })
            @Countdown(3)
            @Link("profile", 42)

            <div>
                <span>Send feedback to <a href="mailto:info@example.com">info@@example.com</a></span>
            </div>
            <input disabled>
            <input disabled="{showDisabled}">
        </body>
    </html>
}
