const std = @import("std");

const card = zimport("components/card.zempl");
const Card = card.Card;
const list = zimport("components/list.zempl");
const List = list.List;

zempl Countdown(count: u32) {
    <div class="countdown">
        @{ var n = count; }
        @while (n > 0) {
            <span>{n}</span>
            @{ n -= 1; }
        }
        <span>Done!</span>
    </div>
}

zempl Link(href: []const u8, userId: u32) {
    @{
        var buf: [100]u8 = undefined;
        const url = try std.fmt.bufPrint(&buf, "/{s}/{d}", .{ href, userId });
    }
    <a href={url}>Click here</a>
}

pub zempl Page(name: []const u8) {
    <!DOCTYPE html>
    <html>
        <head>
            <title>{name}</title>
        </head>
        <body>
            @Card("Welcome", true)
            @List(&.{ "apple", "banana", "cherry" })
            @Countdown(3)
            @Link("profile", 42)
        </body>
    </html>
}
